# docker compose 가 자동 로드하는 루트 환경파일.
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 .gitignore 처리됨)

# 외부 노출 포트
MYTREND_PORT=8000

# 동작 설정
MYTREND_INGEST_INTERVAL_MIN=20
MYTREND_DEFAULT_HOURS=24
MYTREND_PER_FEED_LIMIT=60
MYTREND_CACHE_TTL=120
MYTREND_INGEST_ON_START=true

# API 키 (비워두면 해당 소스 자동 비활성)
TAVILY_API_KEY=
EODHD_API_TOKEN=
NEWSAPI_KEY=
# OpenRouter (LLM 게이트웨이) — 트렌드 요약 등 LLM 기능용
OPENROUTER_API_KEY=
