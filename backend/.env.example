# ── MyTrend 백엔드 환경설정 ──
# 이 파일을 .env 로 복사한 뒤 키를 채우세요. 키가 없는 소스는 자동으로 비활성화됩니다.

# Tavily (뉴스 검색 API) — https://tavily.com
TAVILY_API_KEY=

# EODHD (금융/경제 뉴스 API) — https://eodhd.com  (EODHD_API_KEY 또는 EODHD_API_TOKEN)
EODHD_API_TOKEN=

# NewsAPI.org (선택) — https://newsapi.org
NEWSAPI_KEY=

# OpenRouter (LLM 게이트웨이) — AI 브리핑·라벨링·Q&A
OPENROUTER_API_KEY=
MYTREND_AI_MODEL=openai/gpt-4o-mini

# ── 동작 설정 ──
# PostgreSQL 접속 문자열(DSN). Docker compose 가 자동 주입하므로 보통 비워둬도 됨.
# 직접(uvicorn) 실행 시에만 채우면 됨. 예: postgresql://mytrend:mytrend@localhost:5432/mytrend
MYTREND_DATABASE_URL=postgresql://mytrend:mytrend@localhost:5432/mytrend
# 스케줄러 수집 주기(분). 0 이면 스케줄러 비활성화
MYTREND_INGEST_INTERVAL_MIN=20
# 트렌드 기본 시간창(시간)
MYTREND_DEFAULT_HOURS=24
# 소스·피드당 최대 기사 수
MYTREND_PER_FEED_LIMIT=60
# 캐시 TTL(초). 동일 조건 트렌드 재계산 최소 간격
MYTREND_CACHE_TTL=120
# 시작 시 1회 즉시 수집 여부
MYTREND_INGEST_ON_START=true
# 원시 기사 보존 기간(일). 이후 기사는 삭제되나 일별 롤업(daily_keyword)은 영구 보존
MYTREND_ARTICLE_RETENTION_DAYS=120
