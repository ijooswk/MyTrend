# 원격 배포 자격증명 / 설정.
# 이 파일을 deploy.env 로 복사해 값을 채우세요. (deploy.env 는 .gitignore 처리됨)

# 원격 서버
REMOTE_HOST=100.98.178.217
REMOTE_USER=sehun
REMOTE_PORT=22

# 인증: SSH 키 사용을 권장. 키가 없으면 비밀번호(sshpass) 사용.
#   - 키 사용 시 REMOTE_PASS 는 비워두세요.
#   - 비밀번호 사용 시 sshpass 가 로컬에 설치되어 있어야 합니다.
REMOTE_PASS=

# 원격에서 프로젝트가 위치할 경로
REMOTE_DIR=~/mytrend

# 외부 노출 포트
MYTREND_PORT=8000
