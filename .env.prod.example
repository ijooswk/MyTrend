# ──────────────────────────────────────────────────────────────────────────────
# 프로덕션 배포용 compose 환경변수 템플릿.
# 서버에서 `cp .env.prod.example .env` 후 값을 조정하세요.
# (docker-compose.prod.yml 이 이 .env 를 자동으로 읽습니다)
#
# 참고: EODHD / OPENROUTER / TAVILY 등 외부 API 키는 backend/.env 에서 관리합니다.
#       이 파일은 포트·동작 등 compose 레벨 설정만 담습니다.
# ──────────────────────────────────────────────────────────────────────────────

# ── 공개 포트 (서버에서 이미 쓰는 80/8000/18000/18080/19000/19080 등을 피해 선정) ──
# host 네트워크라 nginx(프론트)가 이 포트로 호스트 인터페이스에 직접 바인딩한다.
# 메인 진입점: http://100.98.178.217:19090
MYTREND_PORT=19090

# ── 백엔드 내부 포트 (외부 비공개; nginx 가 127.0.0.1 로 프록시) ──
# 서버에서 이미 점유된 포트와 겹치지 않게 선택.
MYTREND_API_PORT=8001

# ── PostgreSQL (db 서비스. 외부 비공개=127.0.0.1) ──
# ★ 운영 배포 전 POSTGRES_PASSWORD 를 강력한 값으로 반드시 변경.
POSTGRES_USER=mytrend
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mytrend
# host 네트워크라 이 포트가 서버에서 직접 점유됨. 서버에 이미 PostgreSQL(5432)이 있으면
# 충돌하므로 비는 포트로 변경(예: 55432). 변경 시 db·backend 가 함께 이 값을 사용.
POSTGRES_PORT=5432

# ── 동작 ──
MYTREND_INGEST_INTERVAL_MIN=20      # 수집 주기(분)
MYTREND_DEFAULT_HOURS=24            # 트렌드 기본 시간창
MYTREND_PER_FEED_LIMIT=60           # 소스·피드당 최대 기사 수
MYTREND_CACHE_TTL=120               # 트렌드 캐시 TTL(초)
MYTREND_INGEST_ON_START=true        # 시작 시 1회 즉시 수집
MYTREND_ARTICLE_RETENTION_DAYS=120  # 기사 보존(일). 이후 기사 삭제·일별 롤업은 영구 보존

# ── AI ──
MYTREND_AI_MODEL=openai/gpt-4o-mini # OpenRouter 모델(키는 backend/.env)
